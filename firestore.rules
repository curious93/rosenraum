rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Räume ──────────────────────────────────────────────────────────────────
    match /rooms/{roomId} {

      // Raum lesen: offen (roomId ist 20-stellig zufällig — kein Brute-Force möglich)
      allow read: if true;

      // Raum erstellen: immer erlaubt
      allow create: if true;

      // Raum updaten: gesperrt (Felder sind immutable)
      allow update: if false;
      allow delete: if false;

      // ── Participants ─────────────────────────────────────────────────────────
      match /participants/{participantId} {
        allow read: if true;

        // Beitreten: immer erlaubt (Limit von 2 wird in App-Logik geprüft)
        allow create: if true;

        // Eigenen Eintrag updaten (z.B. rosenbergMode)
        allow update: if true;
        allow delete: if false;
      }

      // ── Nachrichten ──────────────────────────────────────────────────────────
      match /messages/{messageId} {
        allow read: if true;

        // Nachricht senden: senderId muss als Participant existieren
        allow create: if exists(/databases/$(database)/documents/rooms/$(roomId)/participants/$(request.resource.data.senderId))
          && request.resource.data.keys().hasAll(['senderId', 'sentVersion', 'originalText', 'timestamp'])
          && request.resource.data.sentVersion in ['original', 'rosenberg'];

        allow update: if false;
        allow delete: if false;
      }
    }

    // ── Feedback ─────────────────────────────────────────────────────────────
    match /feedback/{feedbackId} {
      // Nur über API-Route schreiben (Admin SDK) — kein direkter Client-Zugriff
      allow read, write: if false;
    }

    // Alle anderen Dokumente sperren
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
