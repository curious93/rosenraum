  "bridge": {
    "comment": "Maps shadcn/ui semantic names to Rosenraum semantic vars so dropped-in ui/ primitives inherit the active theme. Resolved at use-time via var() indirection, so it is emitted once in :root.",
    "map": {
      "background": "bg-page",
      "foreground": "text-primary",
      "card": "bg-surface",
      "card-foreground": "text-primary",
      "popover": "bg-surface",
      "popover-foreground": "text-primary",
      "primary": "primary",
      "primary-foreground": "on-primary",
      "secondary": "bg-elevated",
      "secondary-foreground": "text-secondary",
      "muted": "bg-elevated",
      "muted-foreground": "text-muted",
      "accent": "primary-light",
      "accent-foreground": "text-primary",
      "destructive": "destructive",
      "destructive-foreground": "on-primary",
      "border": "border",
      "input": "border",
      "ring": "primary"
    }
  }
