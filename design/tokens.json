{
  "meta": {
    "name": "rosenraum-design-tokens",
    "description": "Single source of truth for all design tokens. Edit here, then run `npm run tokens` to regenerate src/app/tokens.generated.css. Never edit the generated file by hand.",
    "defaultPreset": "rose",
    "themeStandard": "3 canonical families (default | expressive | minimal), each light + dark. Rosenraum ships 6 expressive presets (rose/forst/lila/ozean/koralle/meer), grandfathered under the Expressive family. See docs/THEME_OPTIONS.md."
  },

  "primitive": {
    "radius": {
      "sm": "8px",
      "md": "12px",
      "lg": "14px",
      "bubble": "18px",
      "bubble-tail": "4px"
    },
    "layout": {
      "max-width-chat": "680px",
      "max-width-sheet": "480px",
      "input-height": "52px"
    },
    "shadow": {
      "sm": "0 2px 8px rgba(0,0,0,0.06)",
      "md": "0 4px 24px rgba(0,0,0,0.10)",
      "up": "0 -4px 24px rgba(0,0,0,0.10)"
    },
    "motion": {
      "ease-spring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "ease-smooth": "cubic-bezier(0.25, 0.46, 0.45, 0.94)",
      "ease-in-out": "cubic-bezier(0.4, 0, 0.2, 1)",
      "duration-instant": "100ms",
      "duration-fast": "200ms",
      "duration-base": "300ms",
      "duration-slow": "500ms"
    },
    "typography": {
      "font-body": "'Inter', system-ui, -apple-system, sans-serif",
      "size-micro": "0.75rem",
      "size-small": "0.875rem",
      "size-body": "1rem",
      "size-heading": "1.25rem",
      "size-hero": "clamp(1.75rem, 5vw, 2.5rem)",
      "weight-normal": "400",
      "weight-medium": "500",
      "weight-bold": "600",
      "leading-tight": "1.25",
      "leading-body": "1.5",
      "leading-loose": "1.75"
    }
  },

  "semantic": {
    "tokens": [
      "primary", "primary-light", "primary-dark",
      "bg-page", "bg-surface", "bg-elevated",
      "bubble-own", "bubble-other", "bubble-gfk",
      "text-primary", "text-secondary", "text-muted",
      "border", "border-subtle",
      "dot-learning", "skeleton",
      "success", "warning", "destructive",
      "on-primary"
    ],
    "statusDefaults": {
      "light": {
        "success": "#2F855A",
        "warning": "#B7791F",
        "destructive": "#C0392B",
        "on-primary": "#FFFFFF"
      },
      "dark": {
        "success": "#68D391",
        "warning": "#ECC94B",
        "destructive": "#FC8181",
        "on-primary": "#FFFFFF"
      }
    },

    "presets": {
